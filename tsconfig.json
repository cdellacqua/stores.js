{
	"compilerOptions": {
		"target": "ESNext",
		"useDefineForClassFields": true,
		"module": "NodeNext",
		"lib": ["ES2022", "DOM"],
		"moduleResolution": "NodeNext",
		"types": ["node", "vitest/globals"],
		"strict": true,
		"sourceMap": true,
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"noEmit": true,
		"skipLibCheck": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true
	},
	"include": ["./src", "./tests"]
}
